# ─────────────────────────────────────────────────────────────────────────────
# Confetti — environment variables
# Copy to `.env.local` for local dev, and set the same keys in your Vercel
# project (Production + Preview). Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the deployment (used to build guest-upload / gallery links
# and QR codes). No trailing slash.
NEXT_PUBLIC_APP_URL=https://event-gallery-app-rho.vercel.app

# Server-side secret used to sign gallery cookies, hash IPs and sign upload
# grants. REQUIRED in production (the app refuses to boot without it). Generate
# a strong random value, e.g.:  openssl rand -hex 32
APP_SECRET=

# ── Supabase (auth + database) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only. NEVER expose to the client / prefix with
# NEXT_PUBLIC. Used by admin/internal server code.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudflare R2 (object storage for media) ─────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL for objects, if the bucket is served via a public/custom
# domain. Leave blank to use signed download URLs instead.
R2_PUBLIC_BASE_URL=

# ── Payments — Payhip (active provider) ──────────────────────────────────────
# Token used to verify incoming Payhip webhooks.
PAYHIP_WEBHOOK_SECRET=
# Payhip product keys per plan. One Event is live; the photographer
# subscription products still need to be created in Payhip before launch.
PAYHIP_PRODUCT_ONE_EVENT=
PAYHIP_PRODUCT_SOLO_MONTHLY=
PAYHIP_PRODUCT_SOLO_YEARLY=
PAYHIP_PRODUCT_PRO_MONTHLY=
PAYHIP_PRODUCT_PRO_YEARLY=

# ── Internal job secrets ─────────────────────────────────────────────────────
# Shared secret required to call the internal media-processing endpoint.
MEDIA_WORKER_SECRET=
# Shared secret required to trigger scheduled/cron jobs (e.g. purge deleted).
CRON_SECRET=

# ── Dev only ─────────────────────────────────────────────────────────────────
# Comma-separated dev origins allowed by Next during local development.
ALLOWED_DEV_ORIGINS=http://localhost:3000,http://localhost:3001

# ── LemonSqueezy (LEGACY / dormant — optional) ───────────────────────────────
# The app moved to Payhip; these are only read by dormant fallback code paths.
# Leave blank unless you re-enable LemonSqueezy.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_SOLO_MONTHLY=
LEMONSQUEEZY_VARIANT_SOLO_YEARLY=
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=
LEMONSQUEEZY_VARIANT_PRO_YEARLY=
